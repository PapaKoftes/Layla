#!/usr/bin/env sh
# Layla launcher (Linux/macOS). Runs the server from the source tree.
# Usage: ./layla [--help] [--host ADDR] [--port N] [--no-browser] [--reload]
DIR="$(cd "$(dirname "$0")" && pwd)"
# Prefer the project venv the installer created; fall back to PATH python.
if [ -x "$DIR/.venv/bin/python" ]; then
  PY="$DIR/.venv/bin/python"
else
  PY="$(command -v python3 || command -v python)"
fi
cd "$DIR/agent" || exit 1
exec "$PY" serve.py "$@"
