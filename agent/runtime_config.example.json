{
  "_comment": "Copy this to runtime_config.json and set model_filename. Run agent/first_run.py to auto-generate this for your hardware.",

  "model_filename": "your-model.gguf",

  "sandbox_root": "~",

  "uncensored": true,
  "nsfw_allowed": true,
  "knowledge_unrestricted": true,
  "anonymous_access": true,

  "n_ctx": 4096,
  "n_gpu_layers": -1,
  "n_batch": 512,
  "n_threads": null,
  "n_threads_batch": null,
  "n_keep": 512,

  "use_mmap": true,
  "use_mlock": false,
  "flash_attn": true,
  "type_k": 8,
  "type_v": 8,
  "rope_freq_base": null,
  "rope_freq_scale": null,

  "temperature": 0.2,
  "top_p": 0.95,
  "top_k": 40,
  "repeat_penalty": 1.1,
  "completion_max_tokens": 256,
  "convo_turns": 0,

  "stop_sequences": ["\nUser:", " User:"],

  "max_tool_calls": 5,
  "max_runtime_seconds": 20,
  "tool_routing_enabled": true,
  "use_instructor_for_decisions": true,
  "retrieval_cache_ttl_seconds": 60,
  "auto_lint_test_fix": false,
  "auto_lint_test_fix_run_tests": false,
  "retrieval_injection": true,
  "context_compression": true,
  "git_auto_commit": false,
  "research_max_tool_calls": 40,
  "research_max_runtime_seconds": 240,
  "safe_mode": true,

  "use_chroma": true,
  "retrieval_use_mmr": false,
  "retrieval_cross_encoder_limit": 10,

  "knowledge_chunks_k": 5,
  "knowledge_max_bytes": 4000,
  "learnings_n": 30,
  "semantic_k": 5,
  "aspect_memories_n": 10,

  "planning_enabled": true,
  "enable_cognitive_workspace": true,
  "skills_enabled": true,
  "models_dir": "~/.layla/models",
  "capability_impls": {},
  "max_plan_depth": 3,
  "max_mission_runtime_seconds": 3600,
  "max_mission_steps": 10,
  "enable_cot": true,
  "enable_self_reflection": false,
  "custom_system_prefix": "",
  "benchmark_on_load": false,
  "hardware_aware_startup": true,

  "scheduler_study_enabled": true,
  "scheduler_interval_minutes": 30,
  "mission_worker_interval_minutes": 2,
  "scheduler_recent_activity_minutes": 90,
  "scheduler_use_capabilities": false,

  "wakeup_include_initiative": false,
  "wakeup_include_discovery_line": false,

  "remote_enabled": false,
  "remote_api_key": null,
  "remote_allow_endpoints": [],
  "remote_mode": "observe",
  "remote_model_name": "layla",
  "llama_server_url": null,
  "inference_backend": "auto",
  "coding_model": null,
  "reasoning_model": null,
  "chat_model": null,
  "model_override_enabled": true,
  "reasoning_budget": -1,
  "reasoning_model": null,

  "discord_webhook_url": null,
  "discord_bot_token": null,
  "slack_bot_token": null,
  "slack_app_token": null,
  "telegram_bot_token": null,
  "spotify_client_id": null,
  "spotify_client_secret": null,
  "slack_webhook_url": null,

  "trace_id_enabled": false,

  "whisper_model": "base",
  "whisper_device": "auto",
  "tts_voice": "af_heart",
  "tts_speed": 1.0,

  "max_ram_percent": 95,
  "max_cpu_percent": 95,
  "web_allowlist": [],

  "knowledge_sources": [
    {"url": "https://fastapi.tiangolo.com/tutorial/first-steps/", "slug": "fastapi-quickstart"},
    {"url": "https://docs.python.org/3/library/asyncio-task.html", "slug": "asyncio-tasks"}
  ],

  "prompt_budget_enabled": true,
  "prompt_budgets": null,

  "enable_personality_expression": false,
  "enable_cognitive_lens": false,
  "enable_behavioral_rhythm": false,
  "enable_lens_refresh": false,
  "lens_refresh_interval_days": 7,
  "enable_lens_knowledge": false,
  "enable_ui_reflection": false,
  "enable_operational_guidance": false,
  "enable_style_profile": false
