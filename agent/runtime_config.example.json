  "trace_id_enabled": false,

  "whisper_model": "base",
  "whisper_device": "auto",
  "tts_voice": "af_heart",
  "tts_speed": 1.0,

  "max_ram_percent": 95,
  "max_cpu_percent": 95,
  "web_allowlist": [],

  "tools_profile": "full",
  "tools_allow": [],
  "tools_deny": [],
  "tool_groups": {},
  "tools_by_provider": {},
  "tool_loop_detection_enabled": false,
  "tool_loop_warning_threshold": 10,
  "tool_loop_stop_threshold": 20,
  "tool_loop_history_size": 30,
  "tool_loop_detect_repeat": true,
  "tool_loop_detect_pingpong": true,
