{
  "_comment": "Copy this to runtime_config.json and set model_filename. Run agent/first_run.py to auto-generate this for your hardware.",

  "model_filename": "your-model.gguf",

  "sandbox_root": "~",

  "uncensored": true,
  "nsfw_allowed": true,
  "knowledge_unrestricted": true,
  "anonymous_access": true,

  "n_ctx": 4096,
  "n_gpu_layers": -1,
  "n_batch": 512,
  "n_threads": null,
  "n_threads_batch": null,
  "n_keep": 512,

  "use_mmap": true,
  "use_mlock": false,
  "flash_attn": true,
  "type_k": 8,
  "type_v": 8,
  "rope_freq_base": null,
  "rope_freq_scale": null,

  "temperature": 0.2,
  "top_p": 0.95,
  "top_k": 40,
  "repeat_penalty": 1.1,
  "completion_max_tokens": 256,
  "convo_turns": 0,

  "stop_sequences": ["\nUser:", " User:"],

  "max_tool_calls": 5,
  "max_runtime_seconds": 20,
  "tool_routing_enabled": true,
  "use_instructor_for_decisions": true,
  "retrieval_cache_ttl_seconds": 60,
  "completion_cache_enabled": false,
  "completion_cache_ttl_seconds": 45,
  "completion_cache_max_entries": 500,
  "telemetry_enabled": true,
  "telemetry_log_trivial": false,
  "_comment_telemetry_log_trivial": "When false, skip DB telemetry rows for reasoning_mode=none (reduces simple-turn ratio pollution).",
  "sandbox_runner_timeout_seconds": 120,
  "sandbox_python_timeout_seconds": 45,
  "sandbox_python_memory_limit_mb": 0,
  "_comment_sandbox_python_memory_limit_mb": "0 = unlimited. On Linux/macOS sets RLIMIT_AS for the child process; ignored on Windows.",
  "max_chars_per_source": 500,
  "retrieval_line_overlap_threshold": 0.7,
  "write_file_max_bytes": 500000,
  "write_file_explosion_factor": 5,
  "max_patch_lines": 0,
  "_comment_max_patch_lines": "0 = unlimited. When set, apply_patch rejects patches with more newline-separated lines.",
  "doc_injection_guard_enabled": true,
  "shell_restrict_to_allowlist": false,
  "shell_allowlist_extra": [],
  "tool_args_validation_enabled": true,
  "coding_model_large_context": null,
  "coding_large_context_threshold": 12000,
  "retrieval_hybrid_vector_weight": 1.0,
  "retrieval_hybrid_bm25_weight": 1.0,
  "retrieval_hybrid_coding_bm25_boost": 1.25,
  "use_bge_reranker": false,
  "bge_reranker_model": "",
  "knowledge_ingestion_enabled": true,
  "multi_agent_orchestration_enabled": false,
  "learning_quality_gate_enabled": false,
  "learning_quality_min_score": 0.35,
  "auto_lint_test_fix": false,
  "auto_lint_test_fix_run_tests": false,
  "retrieval_injection": true,
  "context_compression": true,
  "git_auto_commit": false,
  "research_max_tool_calls": 40,
  "research_max_runtime_seconds": 240,
  "safe_mode": true,

  "use_chroma": true,
  "retrieval_use_mmr": false,
  "retrieval_cross_encoder_limit": 10,

  "knowledge_chunks_k": 5,
  "knowledge_max_bytes": 4000,
  "learnings_n": 30,
  "semantic_k": 5,
  "aspect_memories_n": 10,

  "planning_enabled": true,
  "enable_cognitive_workspace": true,
  "skills_enabled": true,
  "models_dir": "~/.layla/models",
  "capability_impls": {},
  "max_plan_depth": 3,
  "max_mission_runtime_seconds": 3600,
  "max_mission_steps": 10,
  "enable_cot": true,
  "enable_self_reflection": false,
  "custom_system_prefix": "",
  "benchmark_on_load": false,
  "_comment_benchmark_on_load": "When true: model bench on first LLM load; also runs lightweight embedding + vector_search capability benchmarks in a background thread at server startup.",
  "hardware_aware_startup": true,
  "performance_mode": "auto",
  "_comment_performance_mode": "low | mid | high | auto — auto maps from RAM/GPU tiers via system_optimizer.get_effective_config() (runtime only).",
  "models": {
    "default": "",
    "code": "magicoder",
    "fast": "",
    "fallback": ""
  },
  "_comment_models": "Optional aliases: code=magicoder maps to a known GGUF basename under models_dir. coding_model / reasoning_model / chat_model still override when set.",

  "scheduler_study_enabled": true,
  "scheduler_interval_minutes": 30,
