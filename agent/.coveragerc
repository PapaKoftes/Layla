# Used when pytest runs with cwd=agent/ (CI and docs/VERIFICATION.md).
# Measure application code only; omit tests and UI e2e harness.

[run]
branch = True
source = .
omit =
    tests/*
    tests/**/*
    e2e_ui/*
    tui.py
    */__pycache__/*

[report]
# Ratchet: measured branch coverage is ~48%; floor set just below so it can't silently
# regress. Raise this toward the actual number as tests grow — never lower it.
fail_under = 45
precision = 0
show_missing = false
skip_covered = true
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    raise NotImplementedError
